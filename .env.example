# ──────────────────────────────────────────────────────────────────────────────
# API Gateway — Environment Variables
# Copy this file to .env and fill in values before starting.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=development          # development | production

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                # trace | debug | info | warn | error
LOG_PRETTY=true               # true = coloured output (dev); false = JSON (prod)

# ── Data persistence ──────────────────────────────────────────────────────────
DATA_DIR=./data               # directory for JSON file repositories
MAX_REQUEST_LOGS=5000         # rolling cap on stored request records
MAX_FRAUD_EVENTS=2000         # rolling cap on HIGH_RISK event records
MAX_METRIC_SNAPSHOTS=1440     # 24 h × 1-per-minute snapshots

# ── Service ports ─────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
FRAUD_SERVICE_PORT=4001

# ── Upstream service URLs (used by gateway) ───────────────────────────────────
PAYMENT_SERVICE_URL=http://localhost:3001
ACCOUNT_SERVICE_URL=http://localhost:3002
VERIFICATION_SERVICE_URL=http://localhost:3003
FRAUD_SERVICE_URL=http://localhost:4001
FRAUD_SERVICE_TIMEOUT_MS=3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000    # sliding window in milliseconds (default: 1 min)
RATE_LIMIT_MAX_REQUESTS=120   # max requests per IP per window

# ── JWT Authentication (optional) ─────────────────────────────────────────────
# Leave JWT_SECRET empty to disable token auth entirely.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h
REQUIRE_AUTH=false            # set true to enforce Bearer tokens on all /api routes

# ── Fraud detection thresholds ────────────────────────────────────────────────
FRAUD_SUSPICIOUS_THRESHOLD=31     # risk score ≥ this → SUSPICIOUS
FRAUD_HIGH_RISK_THRESHOLD=70      # risk score ≥ this → HIGH_RISK / BLOCKED

# Rule: Rapid Fire
FRAUD_RAPID_FIRE_COUNT=20         # requests before flagging
FRAUD_RAPID_FIRE_WINDOW_MS=60000  # sliding window

# Rule: Payload Anomaly (z-score thresholds)
FRAUD_ZSCORE_HIGH=3.0
FRAUD_ZSCORE_MEDIUM=2.0

# Rule: Sequential Pattern (replay attack)
FRAUD_PATTERN_WINDOW_MS=300000    # 5-minute replay window
FRAUD_PATTERN_COUNT_HIGH=5
FRAUD_PATTERN_COUNT_MEDIUM=3

# Rule: Credential Stuffing
FRAUD_CREDENTIAL_STUFFING_COUNT=5
FRAUD_CREDENTIAL_STUFFING_WINDOW_MS=120000

# Rule: Burst Transfer
FRAUD_BURST_TRANSFER_COUNT=3
FRAUD_BURST_TRANSFER_WINDOW_MS=60000

# Rule: Velocity Spike (EMA multiplier)
FRAUD_VELOCITY_SPIKE_MULTIPLIER=3.0

# ── Per-rule enable/disable ───────────────────────────────────────────────────
RULE_RAPID_FIRE_ENABLED=true
RULE_PAYLOAD_ANOMALY_ENABLED=true
RULE_TIME_BASED_ENABLED=true
RULE_SEQUENTIAL_PATTERN_ENABLED=true
RULE_CREDENTIAL_STUFFING_ENABLED=true
RULE_BURST_TRANSFER_ENABLED=true
RULE_VELOCITY_SPIKE_ENABLED=true

# ── Per-rule weights (contribute to risk score 0–100) ────────────────────────
RULE_RAPID_FIRE_WEIGHT=40
RULE_PAYLOAD_ANOMALY_WEIGHT=35
RULE_TIME_BASED_WEIGHT=15
RULE_SEQUENTIAL_PATTERN_WEIGHT=25
RULE_CREDENTIAL_STUFFING_WEIGHT=30
RULE_BURST_TRANSFER_WEIGHT=35
RULE_VELOCITY_SPIKE_WEIGHT=20
