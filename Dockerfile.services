FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

COPY backend/ ./backend/

ENV NODE_ENV=production
ENV LOG_PRETTY=false

# ARG selects which service to run; override at build time or use docker-compose
ARG SERVICE=payment
CMD ["sh", "-c", "node backend/services/${SERVICE}-service.js"]
